---
layout: null
---
[
{%- for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url }}",
    "content": {{ post.content | strip_html | strip_newlines | strip | replace: " ", "" | replace: "	", "" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{%- endfor %}
]
